# ------------------------------------------------------------------------------
# PromptPass - Public Release Environment Variables
# Copy this file to '.env' to configure local runtime settings.
# ------------------------------------------------------------------------------

# 1. Google Gemini API Key
# Sign up and get a free key at https://aistudio.google.com/
# This is a server-side secret used to run the intelligent exam generator and tutor.
GEMINI_API_KEY="your_google_gemini_api_key_here"

# 2. Local Application Server URL
# Set this to your active local server endpoint (e.g. http://localhost:3000)
# This is used for routing and referencing full-stack endpoints.
APP_URL="http://localhost:3000"
